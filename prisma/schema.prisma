generator client {
  provider      = "prisma-client-js"
  binaryTargets = ["native", "linux-musl-openssl-3.0.x"]
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id              Int       @id @default(autoincrement())
  username        String    @unique @db.VarChar(50)
  email           String    @unique @db.VarChar(100)
  password        String    @db.VarChar(255)
  role            String    @default("user") @db.VarChar(20)
  drawingPoints   Int       @default(10) @map("drawing_points")
  checkinPoints   Int       @default(0) @map("checkin_points")
  creationCount   Int       @default(0) @map("creation_count")
  lastCheckinDate DateTime? @map("last_checkin_date") @db.Date
  checkinCount    Int       @default(0) @map("checkin_count")
  createdAt       DateTime  @default(now()) @map("created_at")

  creations       Creation[]
  apiConfig       UserApiConfig?
  generationTasks GenerationTask[]
  paymentOrders   PaymentOrder[]

  @@map("users")
}

model Creation {
  id        Int      @id @default(autoincrement())
  userId    Int      @map("user_id")
  prompt    String?  @db.Text
  imageUrl  String   @map("image_url") @db.VarChar(255)
  model     String?  @db.VarChar(255)
  size      String?  @db.VarChar(255)
  title     String?  @db.VarChar(100)
  category  String?  @db.VarChar(50)
  referenceImages String? @map("reference_images") @db.Text
  createdAt DateTime @default(now()) @map("created_at")

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("creations")
}

model Inspiration {
  id        Int      @id @default(autoincrement())
  url       String   @db.VarChar(1000)
  prompt    String?  @db.Text
  category  String?  @db.VarChar(50)
  model     String?  @db.VarChar(255)
  createdAt DateTime @default(now()) @map("created_at")

  @@map("inspirations")
}

model Announcement {
  id          Int      @id @default(autoincrement())
  content     String   @db.Text
  isImportant Boolean  @default(false) @map("is_important")
  isActive    Boolean  @default(true) @map("is_active")
  createdAt   DateTime @default(now()) @map("created_at")

  @@map("announcements")
}

model UserApiConfig {
  id         Int      @id @default(autoincrement())
  userId     Int      @unique @map("user_id")
  apiKey     String   @map("api_key") @db.VarChar(500)
  isActive   Boolean  @default(true) @map("is_active")
  usageCount Int      @default(0) @map("usage_count")
  apiBaseUrl String?  @map("api_base_url") @db.VarChar(255)
  createdAt  DateTime @default(now()) @map("created_at")
  updatedAt  DateTime @updatedAt @map("updated_at")

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("user_api_config")
}

model SystemConfig {
  id          Int      @id @default(autoincrement())
  configKey   String   @unique @map("config_key") @db.VarChar(100)
  configValue String?  @map("config_value") @db.Text
  updatedAt   DateTime @default(now()) @map("updated_at")

  @@map("system_config")
}

model ModelConfig {
  id          Int      @id @default(autoincrement())
  modelId     String   @unique @map("model_id") @db.VarChar(100)
  displayName String   @map("display_name") @db.VarChar(100)
  icon        String   @default("🤖") @db.VarChar(20)
  description String   @default("") @db.VarChar(255)
  isEnabled   Boolean  @default(true) @map("is_enabled")
  sortOrder   Int      @default(0) @map("sort_order")
  pointsCost      Int      @default(1) @map("points_cost")
  promptMaxLength Int?     @map("prompt_max_length")
  createdAt       DateTime @default(now()) @map("created_at")
  updatedAt       DateTime @default(now()) @map("updated_at")

  @@map("model_config")
}

model ApiProvider {
  id              Int      @id @default(autoincrement())
  name            String   @db.VarChar(100)
  apiBaseUrl      String   @map("api_base_url") @db.VarChar(500)
  apiKey          String   @map("api_key") @db.VarChar(500)
  priority        Int      @default(0)
  isEnabled       Boolean  @default(true) @map("is_enabled")
  supportedModels String   @default("[]") @map("supported_models") @db.Text
  responseFormat  String   @default("url") @map("response_format") @db.VarChar(20)
  providerType    String   @default("openai") @map("provider_type") @db.VarChar(20)
  createdAt       DateTime @default(now()) @map("created_at")
  updatedAt       DateTime @default(now()) @map("updated_at")

  @@map("api_providers")
}

model GenerationTask {
  id          Int       @id @default(autoincrement())
  userId      Int       @map("user_id")
  status      String    @default("pending") @db.VarChar(20)
  prompt      String?   @db.Text
  model       String?   @db.VarChar(255)
  size        String?   @db.VarChar(50)
  quantity    Int       @default(1)
  result      String?   @db.Text
  error       String?   @db.Text
  createdAt   DateTime  @default(now()) @map("created_at")
  completedAt DateTime? @map("completed_at")

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, status])
  @@map("generation_tasks")
}

// ── 支付系统 ──────────────────────────────────────

model PaymentProvider {
  id         Int       @id @default(autoincrement())
  name       String    @db.VarChar(100)
  channel    String    @db.VarChar(20) // alipay / wechat
  appId      String    @map("app_id") @db.VarChar(100)
  privateKey String    @map("private_key") @db.Text
  publicKey  String    @map("public_key") @db.Text
  notifyUrl  String?   @map("notify_url") @db.VarChar(500)
  priority   Int       @default(0)
  isEnabled  Boolean   @default(true) @map("is_enabled")
  lastUsedAt DateTime? @map("last_used_at")
  metadata   String?   @db.Text // JSON 扩展字段
  createdAt  DateTime  @default(now()) @map("created_at")
  updatedAt  DateTime  @default(now()) @map("updated_at")

  orders PaymentOrder[]

  @@map("payment_providers")
}

model PointsPackage {
  id            Int      @id @default(autoincrement())
  name          String   @db.VarChar(100)
  points        Int
  price         Int      // 售价，单位：分
  originalPrice Int?     @map("original_price") // 原价（划线价），单位：分
  badge         String?  @db.VarChar(50) // 角标：热门、推荐等
  isEnabled     Boolean  @default(true) @map("is_enabled")
  sortOrder     Int      @default(0) @map("sort_order")
  createdAt     DateTime @default(now()) @map("created_at")
  updatedAt     DateTime @default(now()) @map("updated_at")

  orders PaymentOrder[]

  @@map("points_packages")
}

model PaymentOrder {
  id         Int       @id @default(autoincrement())
  orderNo    String    @unique @map("order_no") @db.VarChar(64)
  userId     Int       @map("user_id")
  packageId  Int?      @map("package_id") // null = 直充
  points     Int
  amount     Int       // 实付金额，单位：分
  channel    String    @db.VarChar(20) // alipay / wechat
  providerId Int?      @map("provider_id")
  tradeNo    String?   @map("trade_no") @db.VarChar(100) // 第三方交易号
  status     String    @default("pending") @db.VarChar(20) // pending/paid/failed/expired
  paidAt     DateTime? @map("paid_at")
  expiredAt  DateTime  @map("expired_at")
  createdAt  DateTime  @default(now()) @map("created_at")

  user     User             @relation(fields: [userId], references: [id], onDelete: Cascade)
  package  PointsPackage?   @relation(fields: [packageId], references: [id], onDelete: SetNull)
  provider PaymentProvider? @relation(fields: [providerId], references: [id], onDelete: SetNull)

  @@index([userId, status])
  @@index([status, expiredAt])
  @@map("payment_orders")
}

// ── 本地兜底上传重试队列 ──────────────────────────
model PendingUpload {
  id         Int      @id @default(autoincrement())
  fileKey    String   @map("file_key") @db.VarChar(500)
  localPath  String   @map("local_path") @db.VarChar(1000)
  status     String   @default("pending") @db.VarChar(20)
  retryCount Int      @default(0) @map("retry_count")
  error      String?  @db.Text
  createdAt  DateTime @default(now()) @map("created_at")
  updatedAt  DateTime @default(now()) @map("updated_at")

  @@index([status])
  @@map("pending_uploads")
}

// 注意: _migrations 表由 src/lib/migrator.ts 管理，不在 Prisma schema 中定义
