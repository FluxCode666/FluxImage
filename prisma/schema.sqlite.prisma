// SQLite 备选方案
// 使用方法: 将此文件复制为 schema.prisma，然后运行 prisma generate
// 或运行: npm run db:use-sqlite

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

model User {
  id              Int       @id @default(autoincrement())
  username        String    @unique
  email           String    @unique
  password        String
  role            String    @default("user")
  drawingPoints   Int       @default(10) @map("drawing_points")
  checkinPoints   Int       @default(0) @map("checkin_points")
  creationCount   Int       @default(0) @map("creation_count")
  lastCheckinDate DateTime? @map("last_checkin_date")
  checkinCount    Int       @default(0) @map("checkin_count")
  createdAt       DateTime  @default(now()) @map("created_at")

  creations       Creation[]
  apiConfig       UserApiConfig?
  generationTasks GenerationTask[]

  @@map("users")
}

model Creation {
  id        Int      @id @default(autoincrement())
  userId    Int      @map("user_id")
  prompt    String?
  imageUrl  String   @map("image_url")
  model     String?
  size      String?
  title     String?
  category  String?
  createdAt DateTime @default(now()) @map("created_at")

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("creations")
}

model Inspiration {
  id        Int      @id @default(autoincrement())
  url       String
  prompt    String?
  category  String?
  model     String?
  createdAt DateTime @default(now()) @map("created_at")

  @@map("inspirations")
}

model Announcement {
  id          Int      @id @default(autoincrement())
  content     String
  isImportant Boolean  @default(false) @map("is_important")
  isActive    Boolean  @default(true) @map("is_active")
  createdAt   DateTime @default(now()) @map("created_at")

  @@map("announcements")
}

model UserApiConfig {
  id         Int      @id @default(autoincrement())
  userId     Int      @unique @map("user_id")
  apiKey     String   @map("api_key")
  isActive   Boolean  @default(true) @map("is_active")
  usageCount Int      @default(0) @map("usage_count")
  apiBaseUrl String?  @map("api_base_url")
  createdAt  DateTime @default(now()) @map("created_at")
  updatedAt  DateTime @updatedAt @map("updated_at")

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("user_api_config")
}

model SystemConfig {
  id          Int      @id @default(autoincrement())
  configKey   String   @unique @map("config_key")
  configValue String?  @map("config_value")
  updatedAt   DateTime @default(now()) @map("updated_at")

  @@map("system_config")
}

model ModelConfig {
  id          Int      @id @default(autoincrement())
  modelId     String   @unique @map("model_id")
  displayName String   @map("display_name")
  icon        String   @default("🤖")
  description String   @default("")
  isEnabled   Boolean  @default(true) @map("is_enabled")
  sortOrder   Int      @default(0) @map("sort_order")
  pointsCost      Int      @default(1) @map("points_cost")
  promptMaxLength Int?     @map("prompt_max_length")
  createdAt       DateTime @default(now()) @map("created_at")
  updatedAt       DateTime @default(now()) @map("updated_at")

  @@map("model_config")
}

model ApiProvider {
  id              Int      @id @default(autoincrement())
  name            String
  apiBaseUrl      String   @map("api_base_url")
  apiKey          String   @map("api_key")
  priority        Int      @default(0)
  isEnabled       Boolean  @default(true) @map("is_enabled")
  supportedModels String   @default("[]") @map("supported_models")
  responseFormat  String   @default("url") @map("response_format")
  providerType    String   @default("openai") @map("provider_type")
  createdAt       DateTime @default(now()) @map("created_at")
  updatedAt       DateTime @default(now()) @map("updated_at")

  @@map("api_providers")
}

model GenerationTask {
  id          Int       @id @default(autoincrement())
  userId      Int       @map("user_id")
  status      String    @default("pending")
  prompt      String?
  model       String?
  size        String?
  quantity    Int       @default(1)
  result      String?
  error       String?
  createdAt   DateTime  @default(now()) @map("created_at")
  completedAt DateTime? @map("completed_at")

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, status])
  @@map("generation_tasks")
}
