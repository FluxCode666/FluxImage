# ==============================
# FluxImage Docker 部署环境变量
# 复制此文件为 .env 并修改为实际值
# ==============================

# Docker 镜像（由 CI/CD 自动更新，无需手动修改）
# APP_IMAGE=ghcr.io/your-username/fluximage:latest

# 应用端口映射（宿主机端口）
APP_PORT=3000

# ==============================
# 站点展示（首次启动写入数据库，后续可在管理后台修改）
# ==============================
SITE_NAME=FluxImage
SITE_SUBTITLE=AI Creative Studio

# ==============================
# 数据库 (PostgreSQL)
# 方式一：拆分配置
# ==============================
DB_HOST=your-db-host
DB_PORT=5432
DB_USER=admin
DB_PASSWORD=change-me
DB_NAME=nano_banana
DB_TIMEZONE=Asia/Shanghai

# 方式二：直接配置连接串（优先级高于拆分配置）
# DATABASE_URL=postgresql://admin:change-me@your-db-host:5432/nano_banana

# ==============================
# Redis
# 方式一：拆分配置
# ==============================
REDIS_HOST=your-redis-host
REDIS_PORT=6379
REDIS_PASSWORD=
REDIS_DB=0

# 方式二：直接配置连接串（优先级高于拆分配置）
# REDIS_URL=redis://:password@your-redis-host:6379/0

# ==============================
# JWT 认证
# ==============================
JWT_SECRET=your-jwt-secret-key-here

# ==============================
# 管理员账号（系统启动时自动初始化）
# ==============================
ADMIN_EMAIL=admin@example.com
ADMIN_PASSWORD=admin123456
ADMIN_USERNAME=Admin

# ==============================
# 邮件 SMTP 配置
# ==============================
MAIL_HOST=smtp.qq.com
MAIL_PORT=465
MAIL_USER=your-email@qq.com
MAIL_PASS=your-email-password

# ==============================
# 前端 URL (CORS)
# ==============================
FRONTEND_URL=https://your-domain.com
