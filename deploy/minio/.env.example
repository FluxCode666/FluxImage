# ==============================
# MinIO 环境变量配置
# ==============================

# 管理员账号密码
MINIO_ROOT_USER=admin
MINIO_ROOT_PASSWORD=Admin123456

# 对外暴露端口
MINIO_API_PORT=9000
MINIO_CONSOLE_PORT=9001

# 远程访问地址
# 将 你的服务器IP 替换为服务器公网 IP 或域名
MINIO_SERVER_URL=http://你的服务器IP:9000
MINIO_BROWSER_REDIRECT_URL=http://你的服务器IP:9001
