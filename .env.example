# ==============================
# FluxImage - 环境变量配置
# ==============================

# 运行环境
NODE_ENV=development
PORT=3000

# ==============================
# 站点展示（首次启动写入数据库，后续可在管理后台修改）
# ==============================
SITE_NAME=FluxImage
SITE_SUBTITLE=AI Creative Studio

# ==============================
# 数据库 (PostgreSQL)
# ==============================
DB_HOST=localhost
DB_PORT=5432
DB_USER=admin
DB_PASSWORD=123456
DB_NAME=nano_banana
DB_TIMEZONE=Asia/Shanghai

# ==============================
# Redis
# ==============================
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=
REDIS_DB=0

# ==============================
# JWT 认证
# ==============================
JWT_SECRET=your-jwt-secret-key-here

# ==============================
# 管理员账号（系统启动时自动初始化）
# ==============================
ADMIN_EMAIL=admin@example.com
ADMIN_PASSWORD=admin123456
ADMIN_USERNAME=Admin

# ==============================
# 邮件 SMTP 配置
# ==============================
MAIL_HOST=smtp.qq.com
MAIL_PORT=465
MAIL_USER=your-email@qq.com
MAIL_PASS=your-email-password

# ==============================
# OSS 上传失败本地兜底
# ==============================
LOCAL_FALLBACK_PATH=./uploads

# ==============================
# 前端 URL (CORS)
# ==============================
FRONTEND_URL=http://localhost:3000
